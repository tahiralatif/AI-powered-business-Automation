# ==================== AI & SEARCH ====================
GEMINI_API_KEY=your_gemini_api_key_here
WEB_SEARCH_API=your_google_custom_search_key
Search_Engine_ID=your_google_search_engine_id
GNEWS_API_KEY=your_gnews_api_key_here

# ==================== SOCIAL MEDIA RESEARCH ====================
# Reddit API (PRAW)
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=AI-Co-founder-Bot

# X (Twitter) API
BEARER_TOKEN=your_twitter_bearer_token

# ==================== WEB SCRAPING ====================
FIRECRAWL_API_KEY=your_firecrawl_api_key

# ==================== DATABASE ====================
# SQLite for development (default)
# DATABASE_URL=sqlite:///./ai_cofounder.db

# PostgreSQL for production (uncomment and configure for deployment)
# DATABASE_URL=postgresql://user:password@localhost:5432/ai_cofounder_db

# ==================== SENDGRID EMAIL (Professional Email) ====================
# Get API key from https://sendgrid.com/
SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
SENDGRID_FROM_NAME=AI Co-founder Automation

# ==================== SLACK OAUTH ====================
# Create Slack App at https://api.slack.com/apps
SLACK_CLIENT_ID=your_slack_client_id_here
SLACK_CLIENT_SECRET=your_slack_client_secret_here
SLACK_REDIRECT_URI=http://localhost:8000/slack/callback
SLACK_SCOPES=channels:manage,channels:read,chat:write,chat:write.public,im:write,groups:read

# Legacy Webhook (optional, for backward compatibility)
SLACK_WEBHOOK_URL=your_slack_webhook_url

# ==================== SCHEDULING & BROKER ====================
REDIS_URL=redis://localhost:6379/0

# ==================== SECURITY ====================
# Secret key for JWT tokens (generate with: openssl rand -hex 32)
SECRET_KEY=your_secret_key_here_for_jwt_tokens
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
